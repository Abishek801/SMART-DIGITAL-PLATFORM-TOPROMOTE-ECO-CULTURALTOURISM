# ──────────────────────────────────────────────────────────
# EcoCulture Frontend — Environment Variables
# Copy this file to .env.local and fill in all values
# ──────────────────────────────────────────────────────────

# Database — MySQL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:yourpassword@localhost:3306/ecoculturedb"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="ecoculture-dev-secret-change-in-production"

# Google OAuth (optional — https://console.cloud.google.com/)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Backend API
NEXT_PUBLIC_API_URL="http://localhost:8080/api"

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-api-key"
