# ──────────────────────────────────────────────────────────────
# EcoCulture Spring Boot Backend — Environment Variables
# Set these as env vars or override in application-prod.yml
# ──────────────────────────────────────────────────────────────

# JWT
JWT_SECRET=ecoculture-super-secret-jwt-key-change-in-production-2024

# Mail (for password reset, booking confirmations)
MAIL_USERNAME=noreply@ecoculture.travel
MAIL_PASSWORD=your-smtp-app-password

# For production — replace H2 with PostgreSQL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecoculturedb
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your-db-password
# SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
